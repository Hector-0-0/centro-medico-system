# Copia este archivo a .env y ajusta los valores antes de desplegar:
#   cp .env.example .env
#
# Dominio público de la app (con esto Caddy obtiene el certificado HTTPS).
# Debe apuntar (registro DNS tipo A) a la IP de tu servidor ANTES de levantar.
# Para probar en local puedes dejar "localhost".
DOMAIN=tudominio.com
